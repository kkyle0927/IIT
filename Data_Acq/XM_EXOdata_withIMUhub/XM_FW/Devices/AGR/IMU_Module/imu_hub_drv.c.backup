/**
 * @brief OD Entry 조회 헬퍼 함수
 */
static const AGR_OD_Entry_t* _FindODEntry(uint16_t index, uint8_t subindex)
{
    for (uint32_t i = 0; i < sizeof(s_od_entries) / sizeof(s_od_entries[0]); i++) {
        if (s_od_entries[i].index == index && s_od_entries[i].subindex == subindex) {
            return &s_od_entries[i];
        }
    }
    return NULL;
}

/**
 * @brief SDO Request 처리 콜백 (AGR_DOP)
 * 
 * [CANopen 표준 WriteCb 방식]
 * 1. OD Entry 조회 (_FindODEntry)
 * 2. 데이터 Write (memcpy to data_ptr)
 * 3. WriteCb 호출 (entry->write_cb) ✅
 * 4. Response 생성
 * 
 * [장점]
 * - OD Entry 추가 시 if-else 불필요
 * - WriteCb만 추가하면 확장 가능
 * - CANopen 표준 구조
 * 
 * [호출 경로]
 * ISR: XM_Drv_ProcessCANMessage 
 *   → AGR_PnP_ProcessMessage (NMT, Boot-up, Heartbeat)
 *   → AGR_DOP_ProcessRxMessage (SDO, PDO)
 *   → s_dop_ctx.on_sdo_request (이 함수)
 *   → WriteCb 호출 (_OnPdoMappingA_Set 등) ✅
 */
static void _OnSdoRequest(const AGR_SDO_Msg_t* request, AGR_SDO_Msg_t* response)
{
    const AGR_OD_Entry_t* entry = _FindODEntry(request->index, request->subindex);
    
    if (entry == NULL) {
        /* OD Entry 없음 → Abort */
        response->cs = 0x80;  /* Abort Transfer */
        return;
    }
    
    /* ===== CANopen Download (Write) 요청 처리 ===== */
    if ((request->cs & 0xE0) == 0x20) {  /* Download Initiate Request */
        if (entry->access == AGR_ACCESS_WO || entry->access == AGR_ACCESS_RW) {
            /* 1. 데이터 Write */
            memcpy(entry->data_ptr, request->data, request->data_len);
            
            /* 2. WriteCb 호출 ✅ (CANopen 표준) */
            if (entry->on_write != NULL) {
                entry->on_write();
            }
            
            /* 3. Response 생성 */
            response->cs = AGR_SDO_CS_DOWNLOAD_INIT_RSP;
            response->index = request->index;
            response->subindex = request->subindex;
            response->data_len = 0;
            return;
        }
    }
    
    /* ===== CANopen Upload (Read) 요청 처리 ===== */
    else if ((request->cs & 0xE0) == 0x40) {  /* Upload Initiate Request */
        if (entry->access == AGR_ACCESS_RO || entry->access == AGR_ACCESS_RW) {
            /* 1. 데이터 Read */
            memcpy(response->data, entry->data_ptr, entry->size);
            
            /* 2. Response 생성 (Expedited Upload) */
            uint8_t n = 4 - entry->size;  /* n = 4 - data_len */
            response->cs = 0x43 | (n << 2);  /* Expedited Upload */
            response->index = request->index;
            response->subindex = request->subindex;
            response->data_len = entry->size;
            return;
        }
    }
    
    /* 접근 권한 없음 → Abort */
    response->cs = 0x80;
}

/**
 * @brief 에러 발생 콜백 (AGR_PnP)
 */
static AGR_PnP_RecoveryAction_t _PnP_OnError(uint8_t master_node_id, AGR_PnP_Error_t error_code)
{
    (void)master_node_id;
    (void)error_code;
    
    /* IMU Hub는 재시도 전략 사용 */
    return AGR_PNP_RECOVERY_RETRY;
}

static void _OnPdoReceived(uint32_t cob_id, const uint8_t* data, uint8_t len)
{
    (void)cob_id;
    (void)data;
    (void)len;
    
    /* 현재 IMU Hub는 RPDO를 사용하지 않음 */
}

/**
 * @brief PDO Mapping A 설정 콜백 (OD Entry 0x2010 WriteCb)
 * @note XM10이 SDO를 통해 PDO Mapping A를 설정하면 자동 호출됩니다.
 */
static void _OnPdoMappingA_Set(void)
{
    /* Group A PDO Mapping 설정 → TPDO1 */
    AGR_DOP_ClearTxPDOMapN(&s_dop_ctx, 1);
    
    /* s_pdo_mapping_a는 이미 _OnSdoRequest에서 memcpy로 복사됨 */
    AGR_DOP_ApplyTxPDOMapFromSDON(&s_dop_ctx, 1, s_pdo_mapping_a, 64);
}

/**
 * @brief PDO Mapping B 설정 콜백 (OD Entry 0x2011 WriteCb)
 * @note XM10이 SDO를 통해 PDO Mapping B를 설정하면 자동 호출됩니다.
 */
static void _OnPdoMappingB_Set(void)
{
    /* Group B PDO Mapping 설정 → TPDO2 */
    AGR_DOP_ClearTxPDOMapN(&s_dop_ctx, 2);
    
    /* s_pdo_mapping_b는 이미 _OnSdoRequest에서 memcpy로 복사됨 */
    AGR_DOP_ApplyTxPDOMapFromSDON(&s_dop_ctx, 2, s_pdo_mapping_b, 64);
}

/* 
 * ✅ CANopen 표준 처리 흐름 (V3.0)
 * 
 * [프로토콜별 처리]
 * 1. Boot-up (CAN ID 0x700 + Node ID)
 *    → AGR_PnP_ProcessMessage()
 *    → _PnP_OnBootup()
 * 
 * 2. NMT (CAN ID 0x000)
 *    → AGR_NMT_ProcessMessage()
 *    → _PnP_OnNmtChange()
 * 
 * 3. Heartbeat (CAN ID 0x700 + Node ID)
 *    → AGR_PnP_ProcessMessage()
 *    → Heartbeat Timeout 체크
 * 
 * 4. SDO (CAN ID 0x600 + Node ID)
 *    → AGR_DOP_ProcessRxMessage()
 *    → _OnSdoRequest()
 *    → OD Entry 조회
 *    → WriteCb 호출 (_OnPdoMappingA_Set 등) ✅
 * 
 * 5. PDO (CAN ID 0x180/0x280 + Node ID)
 *    → AGR_DOP_ProcessRxMessage()
 *    → _OnPdoReceived()
 */

/* ===== SDO Tx Helper Functions ===== */

/**
 * @brief XM10에 캘리브레이션 상태 전송
 */
int XM_Drv_SendCalibrationStatus(uint8_t status)
{
    /* 내부 변수 업데이트 */
    s_tx_data.calibration_status = status;
    
    /* XM10에 SDO 전송 */
    return AGR_DOP_SendSDOWrite(&s_dop_ctx, 
                                0x3001,  // OD Index
                                0,       // Subindex
                                &status, 
                                1);
}

/**
 * @brief XM10에 에러 코드 전송
 */
int XM_Drv_SendErrorCode(uint16_t error_code)
{
    /* 내부 변수 업데이트 */
    s_tx_data.error_code = error_code;
    
    /* XM10에 SDO 전송 */
    return AGR_DOP_SendSDOWrite(&s_dop_ctx, 
                                0x3002, 
                                0, 
                                &error_code, 
                                sizeof(uint16_t));
}

/**
 * @brief XM10에 센서 건강 상태 전송
 */
int XM_Drv_SendSensorHealth(const uint8_t health[6])
{
    if (health == NULL) {
        return -1;
    }
    
    /* 내부 변수 업데이트 */
    memcpy(s_tx_data.sensor_health, health, 6);
    
    /* XM10에 SDO 전송 */
    return AGR_DOP_SendSDOWrite(&s_dop_ctx, 
                                0x3003, 
                                0, 
                                s_tx_data.sensor_health, 
                                6);
}

